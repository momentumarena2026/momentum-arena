generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum Sport {
  CRICKET
  FOOTBALL
  PICKLEBALL
  BADMINTON
}

enum ConfigSize {
  XS
  SMALL
  MEDIUM
  LARGE
  XL
  FULL
  SHARED
}

enum CourtZone {
  LEATHER_1
  BOX_A
  BOX_B
  LEATHER_2
  SHARED_COURT
}

enum BookingStatus {
  LOCKED
  CONFIRMED
  CANCELLED
}

enum PaymentMethod {
  RAZORPAY
  UPI_QR
  CASH
  FREE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  REFUNDED
  FAILED
}

enum DayType {
  WEEKDAY
  WEEKEND
}

enum TimeType {
  PEAK
  OFF_PEAK
}

enum DiscountType {
  PERCENTAGE
  FLAT
}

enum BannerPlacement {
  BOOK_PAGE
  SLOT_SELECTION
  CHECKOUT
}

enum AdminRole {
  SUPERADMIN
  ADMIN
  STAFF
}

// ===========================
// UNIFIED COUPON SYSTEM
// ===========================

enum CouponScope {
  SPORTS
  CAFE
  BOTH
}

enum CouponConditionType {
  MIN_AMOUNT
  FIRST_PURCHASE
  USER_GROUP
  SPORT_SPECIFIC
  CATEGORY_SPECIFIC
  TIME_WINDOW
  BIRTHDAY
  REFERRAL
}

enum UserGroupType {
  FIRST_TIME
  PREMIUM_PLAYER
  FREQUENT_VISITOR
  BIRTHDAY_MONTH
  CUSTOM
}

// ===========================
// REWARD POINTS
// ===========================

enum RewardTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum PointsTransactionType {
  EARNED_BOOKING
  EARNED_CAFE
  EARNED_REFERRAL
  EARNED_BONUS
  REDEEMED_BOOKING
  REDEEMED_CAFE
  EXPIRED
  ADJUSTMENT
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  phone         String?   @unique
  emailVerified DateTime?
  phoneVerified DateTime?
  image         String?
  passwordHash  String?
  passwordSetAt DateTime?
  role          UserRole  @default(CUSTOMER)
  accounts      Account[]
  sessions      Session[]
  bookings      Booking[]
  cafeOrders    CafeOrder[]
  referralCode  String?   @unique
  referredBy    String?
  birthday      DateTime?

  rewardBalance RewardPointsBalance?

  // New feature relations
  feedbacks         Feedback[]
  waitlistEntries   Waitlist[]
  recurringBookings RecurringBooking[]
  wallet            Wallet?

  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  attempts   Int      @default(0)

  @@unique([identifier, token])
}

model RateLimit {
  id         String   @id @default(cuid())
  identifier String
  action     String
  count      Int      @default(1)
  windowStart DateTime @default(now())

  @@unique([identifier, action])
}

model CourtConfig {
  id        String      @id @default(cuid())
  sport     Sport
  size      ConfigSize
  label     String
  position  String
  widthFt   Int
  lengthFt  Int         @default(90)
  zones     CourtZone[]
  isActive  Boolean     @default(true)

  bookings          Booking[]
  prices            PricingRule[]
  slotBlocks        SlotBlock[]
  waitlistEntries   Waitlist[]
  recurringBookings RecurringBooking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sport, size, position])
}

model Booking {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  courtConfigId String
  courtConfig   CourtConfig   @relation(fields: [courtConfigId], references: [id])
  date          DateTime      @db.Date
  status        BookingStatus @default(LOCKED)
  lockedAt       DateTime?
  lockExpiresAt  DateTime?
  totalAmount    Int
  originalAmount Int?
  discountAmount Int          @default(0)
  discountCodeId String?

  rewardPointsUsed   Int @default(0)
  rewardPointsEarned Int @default(0)

  createdByAdminId String?
  createdByAdmin   AdminUser? @relation("BookingCreatedByAdmin", fields: [createdByAdminId], references: [id])

  slots       BookingSlot[]
  payment     Payment?
  editHistory BookingEditHistory[]

  // QR check-in
  checkedInAt  DateTime?
  qrToken      String?   @unique @default(cuid())

  // Booking reminders
  reminder24SentAt DateTime?
  reminder2SentAt  DateTime?

  // New feature relations
  feedback         Feedback?
  equipmentRentals EquipmentRental[]
  recurringBookingId String?
  recurringBooking   RecurringBooking? @relation(fields: [recurringBookingId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courtConfigId, date, status])
  @@index([userId])
  @@index([lockExpiresAt])
  @@index([date, status])
}

model BookingSlot {
  id        String  @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  startHour Int
  price     Int

  @@unique([bookingId, startHour])
}

model Payment {
  id                String        @id @default(cuid())
  bookingId         String        @unique
  booking           Booking       @relation(fields: [bookingId], references: [id])
  method            PaymentMethod
  status            PaymentStatus @default(PENDING)
  amount            Int

  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?

  // UPI QR payment tracking
  utrNumber      String?
  utrSubmittedAt DateTime?
  utrVerifiedAt  DateTime?
  utrExpiresAt   DateTime?

  isPartialPayment Boolean @default(false)
  advanceAmount    Int?
  remainingAmount  Int?

  confirmedBy  String?
  confirmedAt  DateTime?
  refundedBy   String?
  refundedAt   DateTime?
  refundReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, method])
  @@index([utrExpiresAt])
}

model PricingRule {
  id            String      @id @default(cuid())
  courtConfigId String
  courtConfig   CourtConfig @relation(fields: [courtConfigId], references: [id])
  dayType       DayType
  timeType      TimeType
  pricePerSlot  Int

  @@unique([courtConfigId, dayType, timeType])
}

model TimeClassification {
  id        String   @id @default(cuid())
  startHour Int
  endHour   Int
  dayType   DayType
  timeType  TimeType

  @@unique([startHour, dayType])
}

model SlotBlock {
  id            String       @id @default(cuid())
  courtConfigId String?
  courtConfig   CourtConfig? @relation(fields: [courtConfigId], references: [id])
  sport         Sport?
  date          DateTime     @db.Date
  startHour     Int?
  reason        String?
  blockedBy     String

  createdAt DateTime @default(now())

  @@index([date, courtConfigId])
  @@index([date, sport])
}

model Notification {
  id        String    @id @default(cuid())
  bookingId String
  channel   String
  status    String
  sentAt    DateTime?
  error     String?

  createdAt DateTime @default(now())

  @@index([bookingId])
}

model PromoBanner {
  id              String            @id @default(cuid())
  title           String
  description     String
  discountInfo    String?
  imageUrl        String?
  placement       BannerPlacement[]
  razorpayOfferId String?
  isActive        Boolean           @default(true)
  startsAt        DateTime
  endsAt          DateTime
  createdBy       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DiscountCode {
  id              String        @id @default(cuid())
  code            String        @unique
  type            DiscountType
  value           Int
  maxUses         Int?
  usedCount       Int           @default(0)
  maxUsesPerUser  Int           @default(1)
  minBookingAmount Int?
  sportFilter     Sport[]
  validFrom       DateTime
  validUntil      DateTime
  isSystemCode    Boolean       @default(false)
  isActive        Boolean       @default(true)
  createdBy       String

  usages    DiscountUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DiscountUsage {
  id             String       @id @default(cuid())
  discountCodeId String
  discountCode   DiscountCode @relation(fields: [discountCodeId], references: [id])
  userId         String
  bookingId      String       @unique
  discountAmount Int

  createdAt DateTime @default(now())

  @@unique([discountCodeId, userId, bookingId])
  @@index([userId])
}

model FAQEntry {
  id        String   @id @default(cuid())
  question  String
  answer    String   @db.Text
  keywords  String[]
  category  String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model AdminUser {
  id                String    @id @default(cuid())
  username          String    @unique
  email             String    @unique
  passwordHash      String
  role              AdminRole @default(ADMIN)
  permissions       String[]
  isDeletable       Boolean   @default(true)
  inviteToken       String?   @unique
  inviteTokenExpiry DateTime?
  lastLoginAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  createdBookings   Booking[]   @relation("BookingCreatedByAdmin")
  createdCafeOrders CafeOrder[] @relation("CafeOrderCreatedByAdmin")
}

model BookingEditHistory {
  id            String   @id @default(cuid())
  bookingId     String
  booking       Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  adminId       String
  adminUsername  String
  editType      String   // CREATED | SLOTS_CHANGED | DATE_CHANGED | COURT_CHANGED

  previousDate          DateTime? @db.Date
  newDate               DateTime? @db.Date
  previousSlots         Int[]
  newSlots              Int[]
  previousCourtConfigId String?
  newCourtConfigId      String?
  previousAmount        Int?
  newAmount             Int?

  note      String?
  createdAt DateTime @default(now())

  @@index([bookingId])
}

// ===========================
// CAFE ORDERING SYSTEM
// ===========================

enum CafeOrderStatus {
  PENDING
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum CafeItemCategory {
  SNACKS
  BEVERAGES
  MEALS
  DESSERTS
  COMBOS
}

model CafeItem {
  id          String           @id @default(cuid())
  name        String
  description String?
  category    CafeItemCategory
  price       Int              // in paise
  image       String?
  isVeg       Boolean          @default(true)
  isAvailable Boolean          @default(true)
  sortOrder   Int              @default(0)
  tags        String[]         // "Bestseller", "New", "Spicy", etc.

  orderItems CafeOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category, isAvailable])
}

model CafeOrder {
  id               String          @id @default(cuid())
  userId           String?
  user             User?           @relation(fields: [userId], references: [id])
  guestName        String?
  guestPhone       String?
  orderNumber      String          @unique
  status           CafeOrderStatus @default(PENDING)
  totalAmount      Int
  originalAmount   Int?
  discountAmount   Int             @default(0)
  discountCodeId   String?
  note             String?
  tableNumber      Int?
  rewardPointsUsed   Int @default(0)
  rewardPointsEarned Int @default(0)

  createdByAdminId String?
  createdByAdmin   AdminUser?      @relation("CafeOrderCreatedByAdmin", fields: [createdByAdminId], references: [id])

  items       CafeOrderItem[]
  payment     CafePayment?
  editHistory CafeOrderEditHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([orderNumber])
}

model CafeOrderItem {
  id         String   @id @default(cuid())
  orderId    String
  order      CafeOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  cafeItemId String
  cafeItem   CafeItem  @relation(fields: [cafeItemId], references: [id])
  itemName   String    // snapshot of name at time of order
  quantity   Int
  unitPrice  Int       // paise
  totalPrice Int       // quantity * unitPrice

  @@index([orderId])
}

model CafePayment {
  id                String        @id @default(cuid())
  orderId           String        @unique
  order             CafeOrder     @relation(fields: [orderId], references: [id])
  method            PaymentMethod
  status            PaymentStatus @default(PENDING)
  amount            Int

  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?

  // UPI QR payment tracking
  utrNumber      String?
  utrSubmittedAt DateTime?
  utrVerifiedAt  DateTime?
  utrExpiresAt   DateTime?

  confirmedBy  String?
  confirmedAt  DateTime?
  refundedBy   String?
  refundedAt   DateTime?
  refundReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, method])
  @@index([utrExpiresAt])
}

model CafeDiscount {
  id             String             @id @default(cuid())
  code           String             @unique
  type           DiscountType
  value          Int                // percentage (basis points) or flat (paise)
  maxUses        Int?
  usedCount      Int                @default(0)
  maxUsesPerUser Int                @default(1)
  minOrderAmount Int?               // minimum order in paise
  categoryFilter CafeItemCategory[]
  validFrom      DateTime
  validUntil     DateTime
  isActive       Boolean            @default(true)
  createdBy      String

  usages CafeDiscountUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CafeDiscountUsage {
  id             String       @id @default(cuid())
  discountId     String
  discount       CafeDiscount @relation(fields: [discountId], references: [id])
  userId         String
  orderId        String       @unique
  discountAmount Int

  createdAt DateTime @default(now())

  @@unique([discountId, userId, orderId])
  @@index([userId])
}

model CafeOrderEditHistory {
  id            String    @id @default(cuid())
  orderId       String
  order         CafeOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  adminId       String
  adminUsername  String
  editType      String    // ITEMS_ADDED | ITEMS_REMOVED | QUANTITY_CHANGED | STATUS_CHANGED | ORDER_CANCELLED | ORDER_CREATED

  previousItems  Json?
  newItems       Json?
  previousAmount Int?
  newAmount      Int?

  note      String?
  createdAt DateTime @default(now())

  @@index([orderId])
}

// ===========================
// UNIFIED COUPON SYSTEM
// ===========================

model Coupon {
  id              String             @id @default(cuid())
  code            String             @unique
  description     String?
  scope           CouponScope        @default(BOTH)
  type            DiscountType
  value           Int                // basis points (percentage) or paise (flat)
  maxDiscount     Int?               // cap on discount amount in paise (for percentage)
  maxUses         Int?               // null = unlimited
  usedCount       Int                @default(0)
  maxUsesPerUser  Int                @default(1)
  minAmount       Int?               // minimum order/booking amount in paise

  // Filters
  sportFilter     Sport[]
  categoryFilter  CafeItemCategory[]
  userGroupFilter UserGroupType[]

  // Behavior
  isStackable     Boolean            @default(false)
  stackGroup      String?
  isPublic        Boolean            @default(true)   // visible on customer coupon page
  isSystemCode    Boolean            @default(false)  // auto-applied (new user, referral, etc.)

  validFrom       DateTime
  validUntil      DateTime
  isActive        Boolean            @default(true)
  createdBy       String

  conditions CouponCondition[]
  usages     CouponUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scope, isActive])
  @@index([code])
}

model CouponCondition {
  id             String              @id @default(cuid())
  couponId       String
  coupon         Coupon              @relation(fields: [couponId], references: [id], onDelete: Cascade)
  conditionType  CouponConditionType
  conditionValue String              // JSON-encoded value

  @@index([couponId])
}

model CouponUsage {
  id             String  @id @default(cuid())
  couponId       String
  coupon         Coupon  @relation(fields: [couponId], references: [id])
  userId         String
  bookingId      String?
  cafeOrderId    String?
  discountAmount Int

  createdAt DateTime @default(now())

  @@unique([couponId, userId, bookingId])
  @@index([userId])
  @@index([couponId])
}

// ===========================
// REWARD POINTS SYSTEM
// ===========================

model RewardPointsBalance {
  id             String      @id @default(cuid())
  userId         String      @unique
  user           User        @relation(fields: [userId], references: [id])
  totalEarned    Int         @default(0)
  totalRedeemed  Int         @default(0)
  currentBalance Int         @default(0)
  tier           RewardTier  @default(BRONZE)

  transactions PointsTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PointsTransaction {
  id          String                @id @default(cuid())
  balanceId   String
  balance     RewardPointsBalance   @relation(fields: [balanceId], references: [id])
  userId      String
  type        PointsTransactionType
  points      Int                   // positive = earn, negative = redeem
  description String
  bookingId   String?
  cafeOrderId String?
  expiresAt   DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([balanceId])
  @@index([expiresAt])
}

model RewardConfig {
  id                 String @id @default(cuid())

  // Earn rates (points per 100 paise / ₹1)
  sportsEarnRate     Int    @default(1)
  cafeEarnRate       Int    @default(2)
  referralBonus      Int    @default(100)

  // Redemption
  pointsPerRupee     Int    @default(10)   // 10 points = ₹1
  minRedeemPoints    Int    @default(100)
  maxRedeemPercent   Int    @default(5000) // 5000 basis points = 50%

  // Tier thresholds (lifetime earned points)
  silverThreshold    Int    @default(500)
  goldThreshold      Int    @default(2000)
  platinumThreshold  Int    @default(5000)

  // Tier multipliers (basis points: 10000 = 1x)
  bronzeMultiplier   Int    @default(10000) // 1x
  silverMultiplier   Int    @default(12500) // 1.25x
  goldMultiplier     Int    @default(15000) // 1.5x
  platinumMultiplier Int    @default(20000) // 2x

  // Expiry
  pointsExpiryDays  Int    @default(365)   // 0 = no expiry

  updatedAt DateTime @updatedAt
}

// ===========================
// CAFE SETTINGS
// ===========================

model CafeSettings {
  id          String @id @default(cuid())
  totalTables Int    @default(10)

  updatedAt DateTime @updatedAt
}
// ===========================
// QR CHECK-IN
// ===========================

// checkedInAt + qrToken added to Booking model via migration

// ===========================
// POST-MATCH FEEDBACK
// ===========================

model Feedback {
  id        String   @id @default(cuid())
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  rating    Int      // 1-5
  comment   String?
  tags      String[] // e.g. ["great_court", "clean", "staff_friendly"]
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([rating])
}

// ===========================
// WAITLIST
// ===========================

enum WaitlistStatus {
  WAITING
  NOTIFIED
  BOOKED
  EXPIRED
  CANCELLED
}

model Waitlist {
  id            String         @id @default(cuid())
  userId        String?
  user          User?          @relation(fields: [userId], references: [id])
  guestPhone    String?
  guestEmail    String?
  courtConfigId String
  courtConfig   CourtConfig    @relation(fields: [courtConfigId], references: [id])
  date          DateTime
  startHour     Int
  endHour       Int
  status        WaitlistStatus @default(WAITING)
  notifiedAt    DateTime?
  expiresAt     DateTime
  createdAt     DateTime       @default(now())

  @@index([userId])
  @@index([courtConfigId, date, status])
}

// ===========================
// EQUIPMENT RENTAL
// ===========================

model Equipment {
  id             String            @id @default(cuid())
  name           String
  sport          Sport?
  pricePerHour   Int               // paise
  totalUnits     Int               @default(1)
  availableUnits Int               @default(1)
  isActive       Boolean           @default(true)
  imageUrl       String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  rentals        EquipmentRental[]
}

model EquipmentRental {
  id          String    @id @default(cuid())
  bookingId   String
  booking     Booking   @relation(fields: [bookingId], references: [id])
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id])
  quantity    Int       @default(1)
  totalPrice  Int       // paise
  createdAt   DateTime  @default(now())

  @@index([bookingId])
  @@index([equipmentId])
}

// ===========================
// RECURRING BOOKINGS
// ===========================

model RecurringConfig {
  id        String @id @default(cuid())

  // Weekly discount tiers stored as JSON: [{ weeks: 4, discountPercent: 5 }, { weeks: 8, discountPercent: 10 }, ...]
  // Sorted by weeks ascending
  tiers     Json   @default("[]")

  // Allowed recurring days (0=Sun … 6=Sat). Empty = all days allowed
  allowedDays Json @default("[0,1,2,3,4,5,6]")

  // Max weeks a customer can book recurring
  maxWeeks  Int    @default(12)

  // Min weeks to qualify for recurring
  minWeeks  Int    @default(2)

  // Daily recurring discount tiers: [{ days: 5, discountPercent: 3 }, { days: 10, discountPercent: 7 }, ...]
  dailyTiers Json @default("[]")

  // Max consecutive days allowed for daily recurring
  maxDays   Int    @default(30)

  // Min days for daily recurring
  minDays   Int    @default(2)

  // Whether recurring bookings are enabled
  enabled   Boolean @default(true)

  updatedAt DateTime @updatedAt
}

enum RecurringStatus {
  ACTIVE
  PAUSED
  CANCELLED
  COMPLETED
}

model RecurringBooking {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  courtConfigId String
  courtConfig   CourtConfig     @relation(fields: [courtConfigId], references: [id])
  startHour     Int
  endHour       Int
  dayOfWeek     Int             // 0=Sun … 6=Sat
  startDate     DateTime
  endDate       DateTime?       // null = indefinite (max 3 months enforced in code)
  mode          String          @default("weekly") // "weekly" or "daily"
  status        RecurringStatus @default(ACTIVE)
  bookings      Booking[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([userId])
  @@index([status])
}

// ===========================
// WALLET
// ===========================

enum WalletTxType {
  CREDIT_REFUND
  CREDIT_TOPUP
  CREDIT_ADMIN
  DEBIT_BOOKING
  DEBIT_CAFE
}

model Wallet {
  id           String             @id @default(cuid())
  userId       String             @unique
  user         User               @relation(fields: [userId], references: [id])
  balancePaise Int                @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  transactions WalletTransaction[]
}

model WalletTransaction {
  id              String       @id @default(cuid())
  walletId        String
  wallet          Wallet       @relation(fields: [walletId], references: [id])
  type            WalletTxType
  amountPaise     Int
  description     String
  refBookingId    String?
  refCafeOrderId  String?
  createdAt       DateTime     @default(now())

  @@index([walletId])
}

// ===========================
// GENERATOR MANAGEMENT
// ===========================

model Generator {
  id          String   @id @default(cuid())
  name        String   // e.g. "Generator 1"
  isActive    Boolean  @default(true)

  fuelLogs    GeneratorFuelLog[]
  oilChanges  GeneratorOilChange[]
  runLogs     GeneratorRunLog[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GeneratorConfig {
  id                    String   @id @default(cuid())

  petrolPricePerLitre   Int      @default(9500)   // paise — ₹95
  oilPricePerLitre      Int      @default(29500)  // paise — ₹295
  consumptionRate       Float    @default(2.0)     // litres per hour

  // Oil change schedule (in running hours)
  firstOilChangeHours   Int      @default(20)
  secondOilChangeHours  Int      @default(50)    // interval after first
  regularOilChangeHours Int      @default(100)   // interval after second, repeating

  // Alert threshold
  oilChangeAlertHours   Int      @default(10)    // send email when X hrs remain

  // Notification emails (comma-separated)
  notificationEmails    String   @default("y12.nakul@gmail.com,tangrianand@gmail.com,saxenautkarsh193@gmail.com,momentumarena2026@gmail.com")

  // MSG91 template IDs
  oilChangeTemplateId   String   @default("Oil_Change_Reminder")
  monthlyTemplateId     String   @default("Generator_Monthly_Summary")
  pinChangeTemplateId   String   @default("generator_pin_change")

  // Mobile access PIN (6-digit)
  generatorPin          String   @default("987065")

  updatedAt             DateTime @updatedAt
}

model GeneratorFuelLog {
  id            String    @id @default(cuid())
  generatorId   String
  generator     Generator @relation(fields: [generatorId], references: [id])

  date          DateTime  @db.Date
  litres        Float                    // litres filled
  pricePerLitre Int                      // paise at time of fill
  totalCost     Int                      // paise (litres * pricePerLitre)

  // Fuel stock tracking
  isStockPurchase Boolean @default(false) // true = bought fuel into stock, false = filled into generator

  notes         String?
  createdAt     DateTime  @default(now())

  @@index([generatorId])
  @@index([date])
}

model GeneratorOilChange {
  id            String    @id @default(cuid())
  generatorId   String
  generator     Generator @relation(fields: [generatorId], references: [id])

  date          DateTime  @db.Date
  runningHoursAtChange Float           // total running hours when oil was changed
  litres        Float     @default(1)  // oil quantity used
  costPerLitre  Int                    // paise at time of change
  totalCost     Int                    // paise
  notes         String?

  // Which change in sequence (1st, 2nd, 3rd...)
  sequenceNumber Int

  createdAt     DateTime  @default(now())

  @@index([generatorId])
  @@index([date])
}

// Optional: manual start/stop logging for accurate runtime tracking
model GeneratorRunLog {
  id            String    @id @default(cuid())
  generatorId   String
  generator     Generator @relation(fields: [generatorId], references: [id])

  startTime     DateTime
  endTime       DateTime?
  durationHours Float?    // calculated from start/end, or manually entered
  notes         String?

  createdAt     DateTime  @default(now())

  @@index([generatorId])
  @@index([startTime])
}
