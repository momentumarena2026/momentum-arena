generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum Sport {
  CRICKET
  FOOTBALL
  PICKLEBALL
}

enum ConfigSize {
  XS
  SMALL
  MEDIUM
  LARGE
  XL
  FULL
  SHARED
}

enum CourtZone {
  LEATHER_1
  BOX_A
  BOX_B
  LEATHER_2
  SHARED_COURT
}

enum BookingStatus {
  PENDING      // UPI/cash committed, awaiting admin verification
  CONFIRMED    // paid & verified — slot is booked
  CANCELLED    // admin-cancelled, refunded, or UPI rejected
}

enum PaymentMethod {
  RAZORPAY
  PHONEPE
  UPI_QR
  CASH
  FREE
}

enum PaymentGateway {
  PHONEPE
  RAZORPAY
}

model PaymentGatewayConfig {
  id              String         @id @default("singleton")
  activeGateway   PaymentGateway @default(PHONEPE)
  // Per-method enablement flags. All default on so existing installs keep
  // their behavior. Admin can toggle any of these off via the Payment
  // Settings page. At least one must stay enabled (enforced server-side).
  onlineEnabled   Boolean        @default(true)
  upiQrEnabled    Boolean        @default(true)
  advanceEnabled  Boolean        @default(true)
  updatedAt       DateTime       @updatedAt
}

enum PaymentStatus {
  PENDING
  // Advance received, remainder still owed (collected at venue for sports
  // bookings, or awaiting a second capture elsewhere). Flips to COMPLETED
  // once the remaining amount is collected via markRemainderCollected.
  PARTIAL
  COMPLETED
  REFUNDED
  FAILED
}

enum DayType {
  WEEKDAY
  WEEKEND
}

enum TimeType {
  PEAK
  OFF_PEAK
}

enum DiscountType {
  PERCENTAGE
  FLAT
}

enum BannerPlacement {
  BOOK_PAGE
  SLOT_SELECTION
  CHECKOUT
}

enum AdminRole {
  SUPERADMIN
  ADMIN
  STAFF
}

// ===========================
// UNIFIED COUPON SYSTEM
// ===========================

enum CouponScope {
  SPORTS
  CAFE
  BOTH
}

enum CouponConditionType {
  MIN_AMOUNT
  FIRST_PURCHASE
  USER_GROUP
  SPORT_SPECIFIC
  CATEGORY_SPECIFIC
  TIME_WINDOW
  BIRTHDAY
  REFERRAL
}

enum UserGroupType {
  FIRST_TIME
  PREMIUM_PLAYER
  FREQUENT_VISITOR
  BIRTHDAY_MONTH
  CUSTOM
}

// ===========================
// REWARD POINTS
// ===========================

enum RewardTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum PointsTransactionType {
  EARNED_BOOKING
  EARNED_CAFE
  EARNED_REFERRAL
  EARNED_BONUS
  REDEEMED_BOOKING
  REDEEMED_CAFE
  EXPIRED
  ADJUSTMENT
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  phone         String?   @unique
  emailVerified DateTime?
  phoneVerified DateTime?
  image         String?
  passwordHash  String?
  passwordSetAt DateTime?
  role          UserRole  @default(CUSTOMER)
  accounts      Account[]
  sessions      Session[]
  bookings      Booking[]
  slotHolds     SlotHold[]
  cafeOrders    CafeOrder[]
  referralCode  String?   @unique
  referredBy    String?
  birthday      DateTime?

  rewardBalance RewardPointsBalance?

  // New feature relations
  feedbacks         Feedback[]
  waitlistEntries   Waitlist[]
  recurringBookings RecurringBooking[]

  // Admin-curated targeting for coupons (vs the auto-computed
  // UserGroupType buckets like FIRST_TIME). `groupMemberships` lets
  // an admin drop a user into named cohorts ("VIP Customers",
  // "Tournament Players"); `couponEligibilities` is a direct,
  // per-user assignment that bypasses any group routing.
  groupMemberships    UserGroupMember[]
  couponEligibilities CouponEligibleUser[]

  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  attempts   Int      @default(0)

  @@unique([identifier, token])
}

model RateLimit {
  id         String   @id @default(cuid())
  identifier String
  action     String
  count      Int      @default(1)
  windowStart DateTime @default(now())

  @@unique([identifier, action])
}

model CourtConfig {
  id        String      @id @default(cuid())
  sport     Sport
  size      ConfigSize
  label     String
  position  String
  widthFt   Int
  lengthFt  Int         @default(90)
  zones     CourtZone[]
  isActive  Boolean     @default(true)

  bookings          Booking[]
  slotHolds         SlotHold[]
  prices            PricingRule[]
  slotBlocks        SlotBlock[]
  waitlistEntries   Waitlist[]
  recurringBookings RecurringBooking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sport, size, position])
}

// Transient slot reservation during checkout (5 min TTL, extended during payment).
// Created when user proceeds from slot-selection to checkout.
// Deleted atomically when user commits to a payment (online success OR UPI "I've paid").
// If user abandons checkout, the hold just expires — no Booking is ever created.
model SlotHold {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  courtConfigId String
  courtConfig   CourtConfig @relation(fields: [courtConfigId], references: [id])
  date          DateTime    @db.Date
  hours         Int[]
  slotPrices    Json        // [{ hour: number, price: number }, ...]
  totalAmount   Int
  expiresAt     DateTime

  // In-flight payment attempt tracking.
  // On payment initiation, expiresAt is extended so the hold survives the
  // payment flow. On success, the hold is deleted and a Booking/Payment is created.
  razorpayOrderId      String?        @unique
  phonePeMerchantTxnId String?        @unique
  paymentMethod        PaymentMethod?
  paymentAmount        Int?
  paymentInitiatedAt   DateTime?

  // Coupon applied during checkout. Persisted on the hold so that when the
  // booking is created (createBookingFromHold) we can record the usage on
  // the Booking row and create a CouponUsage link. None of these are
  // authoritative — they are just a carrier from checkout to booking.
  couponId         String?
  couponCode       String?
  discountAmount   Int?

  // Set true when the hold was created through the unified "Half Court
  // (40x90)" customer flow rather than a direct LEFT/RIGHT selection.
  // The hold still points at a concrete LEFT or RIGHT courtConfigId (the
  // system picks a free half at hold-creation time); this flag just tags
  // the booking lineage so downstream customer-facing displays render the
  // neutral "Half Court" label.
  wasBookedAsHalfCourt Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date, expiresAt])
  @@index([userId])
  @@index([courtConfigId, date])
  @@index([expiresAt])
}

model Booking {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  courtConfigId String
  courtConfig   CourtConfig   @relation(fields: [courtConfigId], references: [id])
  date          DateTime      @db.Date
  status        BookingStatus @default(PENDING)
  totalAmount    Int
  originalAmount Int?
  discountAmount Int          @default(0)
  discountCodeId String?

  rewardPointsUsed   Int @default(0)
  rewardPointsEarned Int @default(0)

  createdByAdminId String?
  createdByAdmin   AdminUser? @relation("BookingCreatedByAdmin", fields: [createdByAdminId], references: [id])

  slots       BookingSlot[]
  payment     Payment?
  editHistory BookingEditHistory[]

  // QR check-in
  checkedInAt  DateTime?
  qrToken      String?   @unique @default(cuid())

  // Booking reminders
  reminder24SentAt DateTime?
  reminder2SentAt  DateTime?

  // New feature relations
  feedback         Feedback?
  equipmentRentals EquipmentRental[]
  recurringBookingId String?
  recurringBooking   RecurringBooking? @relation(fields: [recurringBookingId], references: [id])

  // True when the customer booked through the unified "Half Court
  // (40x90)" flow (medium, no left/right disclosed). Customer-facing
  // displays (confirmation, invoice, "my bookings") read this flag and
  // show "Half Court (40x90)" instead of the concrete LEFT/RIGHT label.
  // Admin-facing displays always show the concrete label. Bookings made
  // before this flow existed default to false and keep their original
  // label everywhere — we do not backfill.
  wasBookedAsHalfCourt Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courtConfigId, date, status])
  @@index([userId])
  @@index([date, status])
}

model BookingSlot {
  id        String  @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  startHour Int
  price     Int

  @@unique([bookingId, startHour])
}

model Payment {
  id                String        @id @default(cuid())
  bookingId         String        @unique
  booking           Booking       @relation(fields: [bookingId], references: [id])
  method            PaymentMethod
  status            PaymentStatus @default(PENDING)
  amount            Int

  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?

  // PhonePe payment tracking
  phonePeMerchantTxnId String?
  phonePeTransactionId String?

  // UPI QR payment tracking
  utrNumber      String?
  utrSubmittedAt DateTime?
  utrVerifiedAt  DateTime?
  utrExpiresAt   DateTime?

  isPartialPayment Boolean @default(false)
  advanceAmount    Int?
  remainingAmount  Int?
  // For partial payments: the method(s) used to collect the venue-side
  // remainder. `method` above continues to represent how the advance was
  // paid.
  //
  // The remainder can be collected as a split between cash and UPI QR.
  // Both amounts live on the row; their sum equals the remainder that was
  // owed. `remainderMethod` is kept as a single-value convenience (set to
  // CASH or UPI_QR when the collection was a single method; left null when
  // the collection was split across both). Legacy rows that predate split
  // collection have only `remainderMethod` set; the display layer falls
  // back to that when the split fields are null.
  remainderMethod     PaymentMethod?
  remainderCashAmount Int?
  remainderUpiAmount  Int?

  confirmedBy  String?
  confirmedAt  DateTime?
  refundedBy   String?
  refundedAt   DateTime?
  refundReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, method])
  @@index([utrExpiresAt])
  // Idempotency-check lookups during webhook retries scale with table size.
  // Without these, Razorpay/PhonePe duplicate-webhook handling degrades to
  // full scans as Payment grows.
  @@index([razorpayPaymentId])
  @@index([phonePeMerchantTxnId])
}

model PricingRule {
  id            String      @id @default(cuid())
  courtConfigId String
  courtConfig   CourtConfig @relation(fields: [courtConfigId], references: [id])
  dayType       DayType
  timeType      TimeType
  pricePerSlot  Int

  @@unique([courtConfigId, dayType, timeType])
}

model TimeClassification {
  id        String   @id @default(cuid())
  startHour Int
  endHour   Int
  dayType   DayType
  timeType  TimeType

  @@unique([startHour, dayType])
}

model SlotBlock {
  id            String       @id @default(cuid())
  courtConfigId String?
  courtConfig   CourtConfig? @relation(fields: [courtConfigId], references: [id])
  sport         Sport?
  date          DateTime     @db.Date
  startHour     Int?
  reason        String?
  blockedBy     String

  createdAt DateTime @default(now())

  @@index([date, courtConfigId])
  @@index([date, sport])
}

model Notification {
  id        String    @id @default(cuid())
  bookingId String
  channel   String
  status    String
  sentAt    DateTime?
  error     String?

  createdAt DateTime @default(now())

  @@index([bookingId])
}

model PromoBanner {
  id              String            @id @default(cuid())
  title           String
  description     String
  discountInfo    String?
  imageUrl        String?
  placement       BannerPlacement[]
  razorpayOfferId String?
  isActive        Boolean           @default(true)
  startsAt        DateTime
  endsAt          DateTime
  createdBy       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DiscountCode {
  id              String        @id @default(cuid())
  code            String        @unique
  type            DiscountType
  value           Int
  maxUses         Int?
  usedCount       Int           @default(0)
  maxUsesPerUser  Int           @default(1)
  minBookingAmount Int?
  sportFilter     Sport[]
  validFrom       DateTime
  validUntil      DateTime
  isSystemCode    Boolean       @default(false)
  isActive        Boolean       @default(true)
  createdBy       String

  usages    DiscountUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DiscountUsage {
  id             String       @id @default(cuid())
  discountCodeId String
  discountCode   DiscountCode @relation(fields: [discountCodeId], references: [id])
  userId         String
  bookingId      String       @unique
  discountAmount Int

  createdAt DateTime @default(now())

  @@unique([discountCodeId, userId, bookingId])
  @@index([userId])
}

model FAQEntry {
  id        String   @id @default(cuid())
  question  String
  answer    String   @db.Text
  keywords  String[]
  category  String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model AdminUser {
  id                String    @id @default(cuid())
  username          String    @unique
  email             String    @unique
  passwordHash      String
  role              AdminRole @default(ADMIN)
  permissions       String[]
  isDeletable       Boolean   @default(true)
  inviteToken       String?   @unique
  inviteTokenExpiry DateTime?
  lastLoginAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  createdBookings   Booking[]   @relation("BookingCreatedByAdmin")
  createdCafeOrders CafeOrder[] @relation("CafeOrderCreatedByAdmin")
}

model BookingEditHistory {
  id            String   @id @default(cuid())
  bookingId     String
  booking       Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  adminId       String
  adminUsername  String
  editType      String   // CREATED | SLOTS_CHANGED | DATE_CHANGED | COURT_CHANGED

  previousDate          DateTime? @db.Date
  newDate               DateTime? @db.Date
  previousSlots         Int[]
  newSlots              Int[]
  previousCourtConfigId String?
  newCourtConfigId      String?
  previousAmount        Int?
  newAmount             Int?

  note      String?
  createdAt DateTime @default(now())

  @@index([bookingId])
}

// ===========================
// CAFE ORDERING SYSTEM
// ===========================

enum CafeOrderStatus {
  PENDING
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum CafeItemCategory {
  SNACKS
  BEVERAGES
  MEALS
  DESSERTS
  COMBOS
}

model CafeItem {
  id          String           @id @default(cuid())
  name        String
  description String?
  category    CafeItemCategory
  price       Int              // in paise
  image       String?
  isVeg       Boolean          @default(true)
  isAvailable Boolean          @default(true)
  sortOrder   Int              @default(0)
  tags        String[]         // "Bestseller", "New", "Spicy", etc.

  orderItems CafeOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category, isAvailable])
}

model CafeOrder {
  id               String          @id @default(cuid())
  userId           String?
  user             User?           @relation(fields: [userId], references: [id])
  guestName        String?
  guestPhone       String?
  orderNumber      String          @unique
  status           CafeOrderStatus @default(PENDING)
  totalAmount      Int
  originalAmount   Int?
  discountAmount   Int             @default(0)
  discountCodeId   String?
  note             String?
  tableNumber      Int?
  rewardPointsUsed   Int @default(0)
  rewardPointsEarned Int @default(0)

  createdByAdminId String?
  createdByAdmin   AdminUser?      @relation("CafeOrderCreatedByAdmin", fields: [createdByAdminId], references: [id])

  items       CafeOrderItem[]
  payment     CafePayment?
  editHistory CafeOrderEditHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([orderNumber])
}

model CafeOrderItem {
  id         String   @id @default(cuid())
  orderId    String
  order      CafeOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  cafeItemId String
  cafeItem   CafeItem  @relation(fields: [cafeItemId], references: [id])
  itemName   String    // snapshot of name at time of order
  quantity   Int
  unitPrice  Int       // paise
  totalPrice Int       // quantity * unitPrice

  @@index([orderId])
}

model CafePayment {
  id                String        @id @default(cuid())
  orderId           String        @unique
  order             CafeOrder     @relation(fields: [orderId], references: [id])
  method            PaymentMethod
  status            PaymentStatus @default(PENDING)
  amount            Int

  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?

  // PhonePe payment tracking
  phonePeMerchantTxnId String?
  phonePeTransactionId String?

  // UPI QR payment tracking
  utrNumber      String?
  utrSubmittedAt DateTime?
  utrVerifiedAt  DateTime?
  utrExpiresAt   DateTime?

  confirmedBy  String?
  confirmedAt  DateTime?
  refundedBy   String?
  refundedAt   DateTime?
  refundReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, method])
  @@index([utrExpiresAt])
  // Same idempotency rationale as Payment — keep cafe webhook lookups fast.
  @@index([razorpayPaymentId])
  @@index([phonePeMerchantTxnId])
}

model CafeDiscount {
  id             String             @id @default(cuid())
  code           String             @unique
  type           DiscountType
  value          Int                // percentage (basis points) or flat (paise)
  maxUses        Int?
  usedCount      Int                @default(0)
  maxUsesPerUser Int                @default(1)
  minOrderAmount Int?               // minimum order in paise
  categoryFilter CafeItemCategory[]
  validFrom      DateTime
  validUntil     DateTime
  isActive       Boolean            @default(true)
  createdBy      String

  usages CafeDiscountUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CafeDiscountUsage {
  id             String       @id @default(cuid())
  discountId     String
  discount       CafeDiscount @relation(fields: [discountId], references: [id])
  userId         String
  orderId        String       @unique
  discountAmount Int

  createdAt DateTime @default(now())

  @@unique([discountId, userId, orderId])
  @@index([userId])
}

model CafeOrderEditHistory {
  id            String    @id @default(cuid())
  orderId       String
  order         CafeOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  adminId       String
  adminUsername  String
  editType      String    // ITEMS_ADDED | ITEMS_REMOVED | QUANTITY_CHANGED | STATUS_CHANGED | ORDER_CANCELLED | ORDER_CREATED

  previousItems  Json?
  newItems       Json?
  previousAmount Int?
  newAmount      Int?

  note      String?
  createdAt DateTime @default(now())

  @@index([orderId])
}

// ===========================
// UNIFIED COUPON SYSTEM
// ===========================

model Coupon {
  id              String             @id @default(cuid())
  code            String             @unique
  description     String?
  scope           CouponScope        @default(BOTH)
  type            DiscountType
  value           Int                // basis points (percentage) or paise (flat)
  maxDiscount     Int?               // cap on discount amount in paise (for percentage)
  maxUses         Int?               // null = unlimited
  usedCount       Int                @default(0)
  maxUsesPerUser  Int                @default(1)
  minAmount       Int?               // minimum order/booking amount in paise

  // Filters
  sportFilter     Sport[]
  categoryFilter  CafeItemCategory[]
  userGroupFilter UserGroupType[]

  // Behavior
  isStackable     Boolean            @default(false)
  stackGroup      String?
  isPublic        Boolean            @default(true)   // visible on customer coupon page
  isSystemCode    Boolean            @default(false)  // auto-applied (new user, referral, etc.)

  validFrom       DateTime
  validUntil      DateTime
  isActive        Boolean            @default(true)
  createdBy       String

  conditions CouponCondition[]
  usages     CouponUsage[]

  // Admin-curated targeting (sits alongside the auto-computed
  // userGroupFilter). When either of these is non-empty the coupon
  // is restricted to the listed users / members of the listed
  // groups. Empty on both means no targeting — anyone can use it.
  // The validation rule is OR: directly-listed users, OR group
  // members, OR userGroupFilter matches all qualify.
  eligibleUsers  CouponEligibleUser[]
  eligibleGroups CouponEligibleGroup[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scope, isActive])
  @@index([code])
}

model CouponCondition {
  id             String              @id @default(cuid())
  couponId       String
  coupon         Coupon              @relation(fields: [couponId], references: [id], onDelete: Cascade)
  conditionType  CouponConditionType
  conditionValue String              // JSON-encoded value

  @@index([couponId])
}

model CouponUsage {
  id             String  @id @default(cuid())
  couponId       String
  coupon         Coupon  @relation(fields: [couponId], references: [id])
  userId         String
  bookingId      String?
  cafeOrderId    String?
  discountAmount Int

  createdAt DateTime @default(now())

  @@unique([couponId, userId, bookingId])
  @@index([userId])
  @@index([couponId])
}

// ===========================
// ADMIN-CURATED USER GROUPS
// ===========================
// Custom cohorts an admin builds by hand (vs the auto-computed
// UserGroupType buckets like FIRST_TIME / PREMIUM_PLAYER). These
// power coupon targeting: a coupon can be restricted to specific
// users (CouponEligibleUser) or to members of specific groups
// (CouponEligibleGroup).

model UserGroup {
  id          String   @id @default(cuid())
  name        String
  description String?

  // Soft-delete so coupons referencing the group keep working until
  // the admin explicitly cleans them up. `members` and `coupons` are
  // both Cascade-deleted on hard delete (rare; mostly for tests).
  deletedAt   DateTime?
  createdBy   String?  // admin userId — nullable so seed data is fine
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members UserGroupMember[]
  coupons CouponEligibleGroup[]

  @@index([deletedAt])
}

model UserGroupMember {
  id      String   @id @default(cuid())
  groupId String
  userId  String
  addedAt DateTime @default(now())

  group UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
}

model CouponEligibleUser {
  id       String   @id @default(cuid())
  couponId String
  userId   String
  addedAt  DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([couponId, userId])
  @@index([userId])
}

model CouponEligibleGroup {
  id       String   @id @default(cuid())
  couponId String
  groupId  String
  addedAt  DateTime @default(now())

  coupon Coupon    @relation(fields: [couponId], references: [id], onDelete: Cascade)
  group  UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([couponId, groupId])
  @@index([groupId])
}

// ===========================
// REWARD POINTS SYSTEM
// ===========================

model RewardPointsBalance {
  id             String      @id @default(cuid())
  userId         String      @unique
  user           User        @relation(fields: [userId], references: [id])
  totalEarned    Int         @default(0)
  totalRedeemed  Int         @default(0)
  currentBalance Int         @default(0)
  tier           RewardTier  @default(BRONZE)

  transactions PointsTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PointsTransaction {
  id          String                @id @default(cuid())
  balanceId   String
  balance     RewardPointsBalance   @relation(fields: [balanceId], references: [id])
  userId      String
  type        PointsTransactionType
  points      Int                   // positive = earn, negative = redeem
  description String
  bookingId   String?
  cafeOrderId String?
  expiresAt   DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([balanceId])
  @@index([expiresAt])
}

model RewardConfig {
  id                 String @id @default(cuid())

  // Earn rates (points per 100 paise / ₹1)
  sportsEarnRate     Int    @default(1)
  cafeEarnRate       Int    @default(2)
  referralBonus      Int    @default(100)

  // Redemption
  pointsPerRupee     Int    @default(10)   // 10 points = ₹1
  minRedeemPoints    Int    @default(100)
  maxRedeemPercent   Int    @default(5000) // 5000 basis points = 50%

  // Tier thresholds (lifetime earned points)
  silverThreshold    Int    @default(500)
  goldThreshold      Int    @default(2000)
  platinumThreshold  Int    @default(5000)

  // Tier multipliers (basis points: 10000 = 1x)
  bronzeMultiplier   Int    @default(10000) // 1x
  silverMultiplier   Int    @default(12500) // 1.25x
  goldMultiplier     Int    @default(15000) // 1.5x
  platinumMultiplier Int    @default(20000) // 2x

  // Expiry
  pointsExpiryDays  Int    @default(365)   // 0 = no expiry

  updatedAt DateTime @updatedAt
}

