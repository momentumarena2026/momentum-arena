// ===========================
// RECURRING BOOKINGS
// ===========================

model RecurringConfig {
  id        String @id @default(cuid())

  // Weekly discount tiers stored as JSON: [{ weeks: 4, discountPercent: 5 }, { weeks: 8, discountPercent: 10 }, ...]
  // Sorted by weeks ascending
  tiers     Json   @default("[]")

  // Allowed recurring days (0=Sun … 6=Sat). Empty = all days allowed
  allowedDays Json @default("[0,1,2,3,4,5,6]")

  // Max weeks a customer can book recurring
  maxWeeks  Int    @default(12)

  // Min weeks to qualify for recurring
  minWeeks  Int    @default(2)

  // Daily recurring discount tiers: [{ days: 5, discountPercent: 3 }, { days: 10, discountPercent: 7 }, ...]
  dailyTiers Json @default("[]")

  // Max consecutive days allowed for daily recurring
  maxDays   Int    @default(30)

  // Min days for daily recurring
  minDays   Int    @default(2)

  // Whether recurring bookings are enabled
  enabled   Boolean @default(true)

  updatedAt DateTime @updatedAt
}

enum RecurringStatus {
  ACTIVE
  PAUSED
  CANCELLED
  COMPLETED
}

model RecurringBooking {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  courtConfigId String
  courtConfig   CourtConfig     @relation(fields: [courtConfigId], references: [id])
  startHour     Int
  endHour       Int
  dayOfWeek     Int             // 0=Sun … 6=Sat
  startDate     DateTime
  endDate       DateTime?       // null = indefinite (max 3 months enforced in code)
  mode          String          @default("weekly") // "weekly" or "daily"
  status        RecurringStatus @default(ACTIVE)
  bookings      Booking[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([userId])
  @@index([status])
}

// ===========================
// GENERATOR MANAGEMENT
// ===========================

model Generator {
  id          String   @id          // manually assigned e.g. "xgen_2026"
  name        String   // e.g. "Generator 1"
  isActive    Boolean  @default(true)

  fuelLogs    GeneratorFuelLog[]
  oilChanges  GeneratorOilChange[]
  runLogs     GeneratorRunLog[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GeneratorConfig {
  id                    String   @id @default(cuid())

  petrolPricePerLitre   Int      @default(9500)   // paise — ₹95
  oilPricePerLitre      Int      @default(29500)  // paise — ₹295
  consumptionRate       Float    @default(2.0)     // litres per hour

  // Oil change schedule (in running hours)
  firstOilChangeHours   Int      @default(20)
  secondOilChangeHours  Int      @default(50)    // interval after first
  regularOilChangeHours Int      @default(100)   // interval after second, repeating

  // Alert threshold
  oilChangeAlertHours   Int      @default(10)    // send email when X hrs remain

  // Notification emails (comma-separated)
  notificationEmails    String   @default("y12.nakul@gmail.com,tangrianand@gmail.com,saxenautkarsh193@gmail.com,momentumarena2026@gmail.com")

  // MSG91 template IDs
  oilChangeTemplateId   String   @default("Oil_Change_Reminder")
  monthlyTemplateId     String   @default("Generator_Monthly_Summary")
  pinChangeTemplateId   String   @default("generator_pin_change")

  // Mobile access PIN (6-digit)
  generatorPin          String   @default("987065")

  // Hardware API key for bulk log endpoint
  hardwareApiKey        String   @default("ma-gen-hw-2026-secret")

  updatedAt             DateTime @updatedAt
}

model GeneratorFuelLog {
  id            String    @id @default(cuid())
  generatorId   String
  generator     Generator @relation(fields: [generatorId], references: [id])

  date          DateTime  @db.Date
  litres        Float                    // litres filled
  pricePerLitre Int                      // paise at time of fill
  totalCost     Int                      // paise (litres * pricePerLitre)

  // Fuel stock tracking
  isStockPurchase Boolean @default(false) // true = bought fuel into stock, false = filled into generator

  notes         String?
  createdAt     DateTime  @default(now())

  @@index([generatorId])
  @@index([date])
}

model GeneratorOilChange {
  id            String    @id @default(cuid())
  generatorId   String
  generator     Generator @relation(fields: [generatorId], references: [id])

  date          DateTime  @db.Date
  runningHoursAtChange Float           // total running hours when oil was changed
  litres        Float     @default(1)  // oil quantity used
  costPerLitre  Int                    // paise at time of change
  totalCost     Int                    // paise
  notes         String?

  // Which change in sequence (1st, 2nd, 3rd...)
  sequenceNumber Int

  createdAt     DateTime  @default(now())

  @@index([generatorId])
  @@index([date])
}

// Optional: manual start/stop logging for accurate runtime tracking
model GeneratorRunLog {
  id            String    @id @default(cuid())
  generatorId   String
  generator     Generator @relation(fields: [generatorId], references: [id])

  entryId       Int?              // sequential ID from device or auto-generated
  source        String  @default("website") // "website" or "hardware"

  startTime     DateTime
  endTime       DateTime?
  durationHours Float?    // calculated from start/end, or manually entered
  notes         String?

  createdAt     DateTime  @default(now())

  @@index([generatorId])
  @@index([startTime])
}

// ===========================
// CACHED DOCUMENTS (PDFs regenerated on a schedule, served at a public URL)
// ===========================

model CachedDocument {
  // String id so the set is extensible (SPORTS_PRICING, CAFE_MENU, ...)
  // without schema churn as new documents are added.
  id          String   @id
  content     Bytes
  mimeType    String   @default("application/pdf")
  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ===========================
// EXPENSES
// Internal cost tracker, modelled after the Playing Zone Mathura spend
// sheet. Replaces the Google Sheet the founders were maintaining by
// hand. Every dropdown on the UI is sourced from ExpenseOption, so
// admins can add / rename / disable categories without a redeploy.
// Amount is stored as whole rupees (Int) — same convention as
// Booking.totalAmount — not paise.
// ===========================

model Expense {
  id          String   @id @default(cuid())
  // Calendar date of the expense (what would be typed into the sheet),
  // independent of createdAt which tracks row entry time.
  date        DateTime @db.Date
  description String
  amount      Int
  // Foreign-key-lite references to ExpenseOption.label: we store the
  // label string rather than an ID so that renaming an option (or
  // hiding it) doesn't orphan historical rows, and a quick text export
  // still shows human-readable values. Filtering joins on label.
  paymentType String // e.g. "Cash" / "Online" — the old "Type" column
  doneBy      String // e.g. "Nakul" / "Utkarsh" / "Anand"
  toName      String // immediate recipient (shop / labour / driver…)
  vendor      String // money-attributed bucket ("Self" / "Landlord" / "SDA")
  spentType   String // category ("Turf" / "Rent" / "Paint"…)
  note        String?

  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  createdByAdminId  String?

  editHistory ExpenseEditHistory[]

  @@index([date])
  @@index([spentType])
  @@index([doneBy])
  @@index([vendor])
  @@index([paymentType])
}

// Audit trail for expense rows. One entry is written on CREATED, and
// another on every edit. `changes` is a JSON array of
// { field, from, to } triples so we don't need a dedicated column per
// mutable field — cheaper to extend when new Expense columns appear.
// adminId + adminUsername are denormalized so the log stays readable
// even if the AdminUser row is later deleted. adminId/username are
// nullable because CSV imports happen without a specific admin actor.
model ExpenseEditHistory {
  id            String   @id @default(cuid())
  expenseId     String
  expense       Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  adminId       String?
  adminUsername String?
  editType      String // CREATED | UPDATED
  changes       Json
  note          String?
  createdAt     DateTime @default(now())

  @@index([expenseId])
  @@index([createdAt])
}

// Which dropdown a given option feeds. Order matches the UI tabs on
// the expense config page so it's easy to reason about.
enum ExpenseOptionField {
  PAYMENT_TYPE
  DONE_BY
  VENDOR
  SPENT_TYPE
  TO_NAME
}

model ExpenseOption {
  id        String             @id @default(cuid())
  field     ExpenseOptionField
  // Displayed + stored form of the option (e.g. "Cash"). Uniqueness
  // scoped to field so "Cash" for PAYMENT_TYPE doesn't collide with
  // the same label in a different field. Disabling (isActive=false)
  // hides the option from new-expense dropdowns but keeps historical
  // rows intact since Expense.* columns store the raw label.
  label     String
  isActive  Boolean            @default(true)
  sortOrder Int                @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([field, label])
  @@index([field, isActive])
}

