DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&connect_timeout=30&pool_timeout=30"
AUTH_SECRET="generate-with: npx auth secret"

# MSG91 (Email + SMS OTP)
MSG91_AUTH_KEY=""
MSG91_TEMPLATE_ID=""
MSG91_SMS_TEMPLATE_ID=""
MSG91_BOOKING_CONFIRMATION_TEMPLATE_ID=""
MSG91_ADMIN_PENDING_BOOKING_TEMPLATE_ID=""

# Admin notification phones (comma-separated with 91 country code)
ADMIN_NOTIFICATION_PHONES="919870437753,919929987404,919027936468"

# Razorpay
RAZORPAY_KEY_ID="rzp_test_xxx"
RAZORPAY_KEY_SECRET="xxx"

# PhonePe Standard Checkout v2 — set per-environment on Vercel
# (sandbox keys for Preview/Development, production keys for
# Production). PHONEPE_ENV controls which API host the SDK targets.
PHONEPE_CLIENT_ID=""
PHONEPE_CLIENT_SECRET=""
PHONEPE_CLIENT_VERSION="1"
PHONEPE_ENV="SANDBOX"  # SANDBOX | PRODUCTION

# PhonePe webhook (S2S callback) auth — configure these in the
# PhonePe dashboard's Webhooks tab; PhonePe sends
# `Authorization: SHA256(username:password)` on every webhook and
# we verify against these env values.
PHONEPE_WEBHOOK_USERNAME=""
PHONEPE_WEBHOOK_PASSWORD=""

# PhonePe Static QR (separate product — venue-side QR codes).
# Still uses the legacy V1 X-VERIFY scheme. Leave unset if you're
# not using static QR webhooks; the route will reject incoming
# callbacks rather than silently accept unverified ones.
PHONEPE_STATIC_QR_SALT_KEY=""
PHONEPE_STATIC_QR_SALT_INDEX="1"

# Cron Secret (for /api/cron/cleanup-locks)
CRON_SECRET="generate-a-random-secret"
