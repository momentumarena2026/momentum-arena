<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Pure black to match the JS splash screen + the app's dark theme.
         Used as the launch window background so there's no white flash
         in the brief moment before the JS splash takes over. Mirrors
         apps/mobile/src/theme/colors.ts -> colors.background. -->
    <color name="splash_background">#000000</color>
    <!-- Adaptive-icon background. Black so the meteor foreground sits on
         the same canvas as the iOS app icon — keeps brand consistency
         across platforms regardless of which mask the launcher applies. -->
    <color name="ic_launcher_background">#000000</color>
</resources>
